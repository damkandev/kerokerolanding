---
const countries = [
  { code: "+56", flag: "🇨🇱", name: "Chile" },
  { code: "+54", flag: "🇦🇷", name: "Argentina" },
  { code: "+55", flag: "🇧🇷", name: "Brasil" },
  { code: "+52", flag: "🇲🇽", name: "México" },
  { code: "+57", flag: "🇨🇴", name: "Colombia" },
  { code: "+51", flag: "🇵🇪", name: "Perú" },
  { code: "+593", flag: "🇪🇨", name: "Ecuador" },
  { code: "+598", flag: "🇺🇾", name: "Uruguay" },
  { code: "+595", flag: "🇵🇾", name: "Paraguay" },
  { code: "+58", flag: "🇻🇪", name: "Venezuela" },
  { code: "+591", flag: "🇧🇴", name: "Bolivia" },
  { code: "+34", flag: "🇪🇸", name: "España" },
];
---

<style>
  /* === Entrada === */
  .contacto-heading { opacity: 0; }
  .field-group { opacity: 0; }

  /* === Campo flotante === */
  .field-inner {
    position: relative;
    padding-top: 22px;
  }

  .field-inner input,
  .field-inner textarea {
    width: 100%;
    background: transparent;
    outline: none;
    border: none;
    border-bottom: 1.5px solid rgba(25, 25, 25, 0.35);
    padding: 8px 0;
    color: #191919;
    font-family: "Work Sans", sans-serif;
    font-size: 1rem;
    letter-spacing: -0.07em;
    resize: none;
    display: block;
    transition: border-color 0.25s ease;
  }

  /* Underline animado */
  .field-inner::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1.5px;
    background: #191919;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }

  .field-inner:focus-within::after {
    transform: scaleX(1);
  }

  /* Label flotante */
  .field-inner label {
    position: absolute;
    left: 0;
    top: 30px;
    font-family: "Work Sans", sans-serif;
    font-size: 1rem;
    letter-spacing: -0.07em;
    color: rgba(25, 25, 25, 0.5);
    pointer-events: none;
    transform-origin: left top;
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
                color 0.25s ease;
  }

  /* Flota cuando tiene foco o contenido */
  .field-inner input:focus ~ label,
  .field-inner input:not(:placeholder-shown) ~ label,
  .field-inner textarea:focus ~ label,
  .field-inner textarea:not(:placeholder-shown) ~ label {
    transform: translateY(-22px) scale(0.72);
    color: rgba(25, 25, 25, 0.75);
  }

  /* === Teléfono (label estático + fila compuesta) === */
  .phone-label {
    font-family: "Work Sans", sans-serif;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    color: rgba(25, 25, 25, 0.65);
    display: block;
    margin-bottom: 2px;
  }

  .phone-row {
    position: relative;
    display: flex;
    align-items: center;
    border-bottom: 1.5px solid rgba(25, 25, 25, 0.35);
  }

  .phone-row::after {
    content: '';
    position: absolute;
    bottom: -1.5px;
    left: 0;
    width: 100%;
    height: 1.5px;
    background: #191919;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
  }

  .phone-row:focus-within::after {
    transform: scaleX(1);
  }

  .select-wrapper {
    position: relative;
    flex-shrink: 0;
  }

  .select-wrapper select {
    background: transparent;
    outline: none;
    border: none;
    color: #191919;
    font-family: "Work Sans", sans-serif;
    font-size: 1rem;
    letter-spacing: -0.07em;
    padding: 8px 20px 8px 0;
    appearance: none;
    -webkit-appearance: none;
    cursor: pointer;
  }

  .select-wrapper::after {
    content: "▾";
    position: absolute;
    right: 4px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 10px;
    color: rgba(25, 25, 25, 0.5);
    pointer-events: none;
  }

  .phone-row input {
    flex: 1;
    background: transparent;
    outline: none;
    border: none;
    color: #191919;
    font-family: "Work Sans", sans-serif;
    font-size: 1rem;
    letter-spacing: -0.07em;
    padding: 8px 0 8px 10px;
    border-left: 1px solid rgba(25, 25, 25, 0.25);
    margin-left: 4px;
  }

  /* === Submit button === */
  .submit-btn {
    position: relative;
    background: #191919;
    color: #c5f09a;
    font-family: "Work Sans", sans-serif;
    font-size: 1rem;
    letter-spacing: -0.07em;
    padding: 14px 40px;
    border: none;
    cursor: pointer;
    overflow: hidden;
    transition: transform 0.15s ease;
  }

  .submit-btn .btn-text {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: gap 0.25s ease;
  }

  .submit-btn .btn-arrow {
    display: inline-block;
    transition: transform 0.25s ease;
  }

  .submit-btn:hover .btn-arrow {
    transform: translateX(4px);
  }

  .submit-btn:hover .btn-text {
    gap: 12px;
  }

  /* Ripple */
  .submit-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(197, 240, 154, 0.07);
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .submit-btn:hover::before { opacity: 1; }
  .submit-btn:active { transform: scale(0.97); }
</style>

<section
  id="contacto"
  class="bg-accent max-w-[1019px] mx-auto border-x border-white grid grid-cols-1 md:grid-cols-[131px_1fr_131px]"
  style="background-image: linear-gradient(rgba(0,0,0,0.06) 1px, transparent 1px), linear-gradient(90deg, rgba(0,0,0,0.06) 1px, transparent 1px); background-size: 48px 48px;"
>
  <div class="hidden md:block"></div>

  <div class="px-6 md:px-0 py-[72px] flex flex-col gap-12">
    <!-- Header -->
    <div class="contacto-heading flex flex-col gap-3">
      <h2 class="font-normal text-[30px] leading-[1.15] tracking-[-0.07em] text-bg">
        Cuéntanos tu problema.
      </h2>
      <p class="text-base leading-relaxed tracking-[-0.07em] text-bg/80 max-w-[460px]">
        Sin compromiso. Te respondemos dentro de las 24 horas con una primera lectura honesta de tu situación.
      </p>
    </div>

    <!-- Form -->
    <form id="contacto-form" class="flex flex-col gap-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-10 gap-y-8">

        <div class="field-group">
          <div class="field-inner">
            <input type="text" name="nombre" placeholder=" " required />
            <label>Nombre</label>
          </div>
        </div>

        <div class="field-group">
          <div class="field-inner">
            <input type="email" name="email" placeholder=" " required />
            <label>Email</label>
          </div>
        </div>

        <div class="field-group">
          <div class="field-inner">
            <input type="text" name="empresa" placeholder=" " />
            <label>Empresa</label>
          </div>
        </div>

        <div class="field-group flex flex-col gap-1">
          <span class="phone-label">Teléfono</span>
          <div class="phone-row">
            <div class="select-wrapper">
              <select name="pais" aria-label="Código de país">
                {countries.map((c) => (
                  <option value={c.code} selected={c.code === "+56"}>
                    {c.flag} {c.code}
                  </option>
                ))}
              </select>
            </div>
            <input type="tel" name="telefono" placeholder="9 0000 0000" required />
          </div>
        </div>

      </div>

      <div class="field-group">
        <div class="field-inner">
          <textarea id="mensaje" name="mensaje" rows="3" placeholder=" " required></textarea>
          <label for="mensaje">¿Cuál es tu problema?</label>
        </div>
      </div>

      <div class="field-group">
        <button type="submit" class="submit-btn">
          <span class="btn-text">
            Enviar mensaje
            <span class="btn-arrow">→</span>
          </span>
        </button>
      </div>
    </form>
  </div>

  <div class="hidden md:block"></div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Entrada del heading
  gsap.fromTo(
    '.contacto-heading',
    { opacity: 0, y: 20 },
    {
      opacity: 1,
      y: 0,
      duration: 0.6,
      ease: 'power2.out',
      scrollTrigger: {
        trigger: '#contacto',
        start: 'top 80%',
        toggleActions: 'play none none reverse',
      },
    }
  );

  // Entrada escalonada por campo
  gsap.fromTo(
    '.field-group',
    { opacity: 0, y: 18 },
    {
      opacity: 1,
      y: 0,
      duration: 0.5,
      ease: 'power2.out',
      stagger: 0.08,
      scrollTrigger: {
        trigger: '#contacto',
        start: 'top 75%',
        toggleActions: 'play none none reverse',
      },
    }
  );

  const form = document.getElementById('contacto-form') as HTMLFormElement;
  const btn = form?.querySelector<HTMLButtonElement>('.submit-btn');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!btn) return;

    const originalText = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="btn-text">Enviando…</span>';

    try {
      const res = await fetch('/api/contacto', { method: 'POST', body: new FormData(form) });
      const json = await res.json();

      if (res.ok) {
        btn.innerHTML = '<span class="btn-text">¡Mensaje enviado! ✓</span>';
        form.reset();
        setTimeout(() => { btn.innerHTML = originalText; btn.disabled = false; }, 3000);
      } else {
        throw new Error(json.error || 'Error desconocido');
      }
    } catch (err) {
      btn.innerHTML = '<span class="btn-text">Error al enviar. Intentá de nuevo.</span>';
      setTimeout(() => { btn.innerHTML = originalText; btn.disabled = false; }, 3000);
    }
  });

  // Textarea: auto-resize al escribir
  const textarea = document.getElementById('mensaje') as HTMLTextAreaElement;
  if (textarea) {
    textarea.addEventListener('input', () => {
      textarea.style.height = 'auto';
      textarea.style.height = textarea.scrollHeight + 'px';
    });
  }
</script>
