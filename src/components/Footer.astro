<footer
  class="bg-[#191919] w-full"
  style="background-image: linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 48px 48px;"
>
  <div class="max-w-[1019px] mx-auto border-x border-t border-white/20 px-6 md:px-[51px] py-8 flex flex-col gap-2 md:flex-row md:items-center md:justify-between">

    <!-- Brand -->
    <div class="flex items-center gap-2">
      <img src="/logo.svg" alt="" class="w-[20px] h-[20px]" />
      <span class="font-display text-base text-white tracking-normal">KeroKero</span>
    </div>

    <!-- Legal -->
    <p class="font-sans text-sm tracking-[-0.04em] text-white/40">
      © {new Date().getFullYear()} KeroKero SpA. Todos los derechos reservados.
    </p>

  </div>
</footer>
