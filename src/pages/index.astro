---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Onboarding from '../components/Onboarding.astro';
import Services from '../components/Services.astro';
import Reglas from '../components/Reglas.astro';
import Contacto from '../components/Contacto.astro';
import Footer from '../components/Footer.astro';

const title = "KeroKero | Software a medida para tu negocio";
const description = "Estudio de software a medida en Latinoamérica. Construimos sistemas operativos críticos, integraciones y SaaS verticales con foco en pocos clientes a la vez.";

const organizationLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "KeroKero",
  "url": "https://kerokero.cl",
  "logo": "https://kerokero.cl/logo.svg",
  "description": description,
  "founders": [
    { "@type": "Person", "name": "Damián Panes", "jobTitle": "CEO" },
    { "@type": "Person", "name": "Felipe Figueroa", "jobTitle": "CTO" }
  ],
  "sameAs": [
    "https://www.linkedin.com/in/damianpanes/",
    "https://www.linkedin.com/in/felipefigueroaf/"
  ]
};

const websiteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "KeroKero",
  "url": "https://kerokero.cl",
  "inLanguage": "es"
};

const servicesLd = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "KeroKero",
  "url": "https://kerokero.cl",
  "areaServed": "Latinoamérica",
  "serviceType": [
    "Software a medida",
    "Integraciones y APIs",
    "SaaS Verticales",
    "IA Aplicada",
    "Consultoría de procesos",
    "Mantenimiento y evolución"
  ]
};
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <SEO
      title={title}
      description={description}
      jsonLd={[organizationLd, websiteLd, servicesLd]}
    />
  </head>
  <body class="bg-bg text-white font-sans antialiased">
    <Navbar />
    <main>
      <Hero />
      <Onboarding />
      <Services />
      <Reglas />
      <Contacto />
    </main>

    <script>
      import Lenis from 'lenis';
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      const lenis = new Lenis({
        duration: 0.8,
        easing: (t) => 1 - Math.pow(1 - t, 3),
        touchMultiplier: 1.5,
      });

      // Sync Lenis with GSAP ScrollTrigger
      lenis.on('scroll', ScrollTrigger.update);
      gsap.ticker.add((time) => lenis.raf(time * 1000));
      gsap.ticker.lagSmoothing(0);

      // Handle anchor clicks for smooth scrolling
      document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
        anchor.addEventListener('click', (e) => {
          const href = (e.currentTarget as HTMLAnchorElement).getAttribute('href');
          if (!href || href === '#') return;
          const target = document.querySelector(href);
          if (target) {
            e.preventDefault();
            lenis.scrollTo(target as HTMLElement);
          }
        });
      });
    </script>
    <Footer />
  </body>
</html>
